# OpenClaw 灾备 .gitignore
# 排除临时文件、多媒体、运行时数据

# Runtime & temp
devices/*.tmp
*.sock
*.lock
*.pid

# Media (too large for git)
media/

# Logs (rotated, not needed in backup)
logs/

# SQLite runtime files (WAL/SHM)
*.sqlite-wal
*.sqlite-shm

# Node/OS temp
node_modules/
.DS_Store
*.swp
*.swo
*~

# Exec approvals (runtime state)
exec-approvals.json

# Update check (runtime)
update-check.json

# Canvas (generated)
canvas/

# Completions (regenerated on install)
completions/

# Task runs (large, runtime)
tasks/

# Cron runs history (regenerated)
cron/runs/

# Backup files (generated by openclaw itself)
*.bak
*.bak.*
workspace/
